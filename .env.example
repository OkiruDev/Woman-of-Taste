PORT=3000
BASE_PATH=/
# public | admin — which router table + frontend bundle this process serves.
# Set to "admin" only on the admin.<domain> Railway service; omit/leave "public" everywhere else.
APP_ROLE=public
DATABASE_URL=postgres://user:password@localhost:5432/woman_of_taste
NODE_ENV=production
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me
APP_URL=http://localhost:3000
SMTP_USER=
SMTP_PASS=
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH_CODE=
BANK_ACCOUNT_TYPE=
BANK_BRANCH_NAME=
BANK_SWIFT_CODE=
# S3-compatible object storage for blog image uploads (Cloudflare R2 recommended)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=
